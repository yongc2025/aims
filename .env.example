# ==============================
# AIMS Environment Configuration
# ==============================

# LLM Provider
LLM_PROVIDER=opencode

# ==============================
# OpenCode Compatible API
# ==============================
OPENCODE_BASE_URL=
OPENCODE_API_KEY=
OPENCODE_MODEL=

# ==============================
# Application
# ==============================
APP_ENV=development
LOG_LEVEL=INFO

# ==============================
# Database
# ==============================
DATABASE_URL=sqlite:///storage/aims.db

# ==============================
# Server
# ==============================
API_HOST=127.0.0.1
API_PORT=8000
